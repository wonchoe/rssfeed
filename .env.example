APP_NAME="rss.cursor.style"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://rss.cursor.style

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rssfeed
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=525600
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=rss.cursor.style
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=redis
CACHE_PREFIX=rssfeed_cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=rssfeed_
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=120

INGESTION_DISCOVERY_TIMEOUT=15
INGESTION_DISCOVERY_FEED_PROBE_ENABLED=true
INGESTION_DISCOVERY_FEED_PROBE_TIMEOUT=8
INGESTION_DISCOVERY_FEED_PROBE_MAX_ATTEMPTS=6
INGESTION_FETCH_TIMEOUT=20
INGESTION_FETCH_RETRY_TIMES=2
INGESTION_FETCH_RETRY_SLEEP_MS=300
INGESTION_FETCH_MAX_PER_DOMAIN_PER_MINUTE=12
INGESTION_FETCH_DOMAIN_RELEASE_SECONDS=15
INGESTION_PAYLOAD_CACHE_TTL=120
INGESTION_PARSED_CACHE_TTL=60
INGESTION_NORMALIZED_CACHE_TTL=60
INGESTION_PARSE_MAX_ITEMS=100
INGESTION_CACHED_SOURCE_FRESH_MINUTES=60
INGESTION_POLL_INACTIVE_SOURCES=false
INGESTION_INACTIVE_POLLING_INTERVAL_MINUTES=1440
INGESTION_COLD_POLLING_INTERVAL_MINUTES=10080
INGESTION_COLD_SOURCE_AFTER_DAYS=30
INGESTION_SCHEDULE_JITTER_SECONDS=120
INGESTION_SCHEDULER_MAX_PER_DOMAIN_PER_CYCLE=2
INGESTION_SCHEDULER_MAX_DISPATCH_PER_CYCLE=180
INGESTION_AI_REPAIR_ENABLED=true
INGESTION_AI_REPAIR_FAILURE_THRESHOLD=3
INGESTION_AI_REPAIR_COOLDOWN_MINUTES=60
INGESTION_AI_REPAIR_USE_OPENAI=true
INGESTION_AI_PREVIEW_MIN_ITEMS=4
INGESTION_SCHEMA_SHADOW_SUCCESS_RUNS_TO_ACTIVATE=2
INGESTION_SCHEMA_VALIDATION_ACTIVATE_SCORE=70
INGESTION_SCHEMA_VALIDATION_MIN_ITEMS=3
INGESTION_SCHEMA_VALIDATION_SNAPSHOT_LIMIT=3
INGESTION_CAPTURE_SNAPSHOTS=true
INGESTION_SNAPSHOT_MAX_BYTES=250000
INGESTION_PREVIEW_IMAGE_ENRICHMENT_ENABLED=true
INGESTION_PREVIEW_IMAGE_ENRICHMENT_MAX_ITEMS=12
INGESTION_PREVIEW_IMAGE_ENRICHMENT_TIMEOUT=6
INGESTION_PREVIEW_IMAGE_ENRICHMENT_TTL=720
INGESTION_USER_AGENT="rss.cursor.style-ingestion-bot/1.0"
FEED_GENERATION_TIMEOUT_SECONDS=180

RATE_LIMIT_FEED_GENERATE=40
RATE_LIMIT_FEED_STATUS=600
RATE_LIMIT_FEED_STREAM=240
RATE_LIMIT_FEED_PROFILE_STREAM=240

ADMIN_ALLOWED_EMAILS=
ADMIN_ALLOW_ALL_LOCAL=true

HORIZON_NAME=rssfeed-local
HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_PREFIX=rssfeed_horizon:
HORIZON_ALLOWED_EMAILS=

SANCTUM_STATEFUL_DOMAINS=rss.cursor.style,rss.cursor.style:8000

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@rss.cursor.style"
MAIL_FROM_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_SCHEMA_MODELS=gpt-5,gpt-5-mini
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
